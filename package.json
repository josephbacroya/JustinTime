{
  "name": "JustInTime",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "build:api": "esbuild src/api/server.ts --bundle --platform=node --target=node22 --outfile=dist/api/server.js",
    "db:deploy": "prisma migrate deploy --schema=src/shared/infrastructure/database/schema.prisma"
  },
  "devDependencies": {
    "@types/chrome": "^0.2.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "esbuild": "^0.28.1",
    "prettier": "^3.7.4",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.1",
    "turbo": "^2.10.5",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.8",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "openai": "^6.48.0"
  }
}
